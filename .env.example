# ================================================================
# Shikshya LMS — Environment Configuration
# Copy this to .env and fill in your values
# ================================================================

# --- Required ---
SECRET_KEY=generate-with-openssl-rand-hex-32

# --- Database ---
# SQLite (default, for dev):
# DATABASE_URL=sqlite:///shikshya.db
# PostgreSQL (production):
DATABASE_URL=postgresql://shikshya:your_password@localhost:5432/shikshya

# --- SMTP Email (for password reset, notifications) ---
# Gmail example (use App Password, not your regular password):
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=Shikshya <your_email@gmail.com>

# --- Site ---
SITE_URL=https://yourdomain.com
FLASK_ENV=production
SESSION_COOKIE_SECURE=True

# --- Rate Limiting Storage ---
# Redis is recommended for production:
# RATELIMIT_STORAGE_URL=redis://localhost:6379/0
